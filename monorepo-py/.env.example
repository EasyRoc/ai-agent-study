# 复制为 .env 后填写真实值；勿提交 .env
# 通义 DashScope（与 Spring AI Alibaba 常见组合）
DASHSCOPE_API_KEY=
# Java 子工程（monorepo-java/java-demo）亦可读（见该处 application.yml）：
# AI_DASHSCOPE_API_KEY=
# 若使用通义，一般无需改；除非官方文档另给 compatible-mode 地址
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# 第 3 周：Embedding（通义 text-embedding-v*，以控制台实际为准）
# EMBEDDING_MODEL=text-embedding-v2

# 日志：week03 / week04 业务 INFO（默认），见 week03.api 内 _configure_app_logging
# LOG_LEVEL=INFO

# 第 3 周：Java 调 Python 向量服务基址（可选；默认 8010）
# APP_VECTOR_BASE_URL=http://127.0.0.1:8010

# 第 3 周：Milvus（不设则默认本机 Milvus Lite → data/milvus_lite.db）
# MILVUS_URI=http://127.0.0.1:19530
# 或独立 Standalone（与 MILVUS_URI 二选一）：
# MILVUS_HOST=127.0.0.1
# MILVUS_PORT=19530
# Zilliz / 认证可配 MILVUS_TOKEN 或 MILVUS_USER + MILVUS_PASSWORD

# 第 4 周 RAG：L0 短期记忆（有 sessionId 时；不写入 Milvus）
# RAG_SESSION_MEMORY_ENABLED=true
# RAG_SESSION_MAX_TURNS=5
# RAG_SESSION_USER_MAX_CHARS=500
# RAG_SESSION_ANSWER_PREVIEW_CHARS=500

# 第 4 周 RAG（可选）
# RAG_TEMPERATURE=0.3
# RAG_LLM_TIMEOUT_SEC=90
# 第 5 周：混合检索（默认开）；false 时仅 Milvus 向量
# RAG_HYBRID_ENABLED=true
# 关键词路取前多少条进 RRF；0 表示自动
# RAG_HYBRID_KW=0
# RRF 融合常数 k
# RAG_RRF_K=60

# Rerank：默认开；向量先 recall 再 qwen3-vl-rerank 截到 top_k（qwen3-vl 单请求最多 100 条 document）
# RAG_RERANK_ENABLED=true
# RAG_RERANK_MODEL=qwen3-vl-rerank
# 可选，指导排序策略，见阿里云「文本排序模型 API」
# RAG_RERANK_INSTRUCT=Given a web search query, retrieve relevant passages that answer the query.
# 仅向量初检条数；不设则取 max(8, top_k*2) 且与 top_k 比较后不超过 100
# RAG_RECALL_TOP_K=16

# 或：OpenAI / 其它 OpenAI-兼容 网关
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
